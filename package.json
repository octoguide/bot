{
	"name": "octoguide",
	"version": "0.21.10",
	"description": "A friendly bot that helps contributors adhere to best practices for your repository on GitHub. 🗺️",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/octoguide/bot.git"
	},
	"license": "MIT",
	"author": {
		"name": "Josh Goldberg ✨",
		"email": "npm@joshuakgoldberg.com"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./lib/index.js"
	},
	"bin": "bin/index.js",
	"files": [
		"lib/"
	],
	"scripts": {
		"build": "tsc",
		"build:release": "ncc build src/action/index.ts -o dist; node postbuild.js",
		"format": "prettier .",
		"lint": "eslint . --max-warnings 0",
		"lint:knip": "knip",
		"lint:md": "markdownlint \"**/*.md\" \".github/**/*.md\" --rules markdownlint-sentences-per-line",
		"lint:packages": "pnpm dedupe --check",
		"lint:spelling": "cspell \"**\" \".github/**/*\"",
		"prepare": "lefthook install",
		"test": "vitest",
		"tsc": "tsc"
	},
	"dependencies": {
		"@actions/core": "^3.0.0",
		"@actions/github": "^9.0.0",
		"@github/markdownlint-github": "^0.8.0",
		"@octokit/plugin-rest-endpoint-methods": "^16.0.0",
		"conventional-commit-types": "^3.0.0",
		"conventional-commits-parser": "^6.1.0",
		"is-comment-meaningless": "^0.2.0",
		"lodash": "^4.17.21",
		"markdown-it": "^14.1.1",
		"markdownlint": "0.41.0",
		"marked": "^18.0.0",
		"octokit": "^5.0.0",
		"octokit-from-auth": "^0.3.1",
		"parse-github-url": "^1.0.3"
	},
	"devDependencies": {
		"@eslint-community/eslint-plugin-eslint-comments": "4.7.0",
		"@eslint/js": "10.0.1",
		"@release-it/conventional-changelog": "11.0.1",
		"@types/eslint-plugin-markdown": "2.0.2",
		"@types/lodash": "4.17.16",
		"@types/markdown-it": "14.1.2",
		"@types/node": "24.13.2",
		"@types/parse-github-url": "1.0.3",
		"@vercel/ncc": "0.44.0",
		"@vitest/coverage-v8": "4.1.0",
		"@vitest/eslint-plugin": "1.6.1",
		"console-fail-test": "0.6.0",
		"cspell": "10.0.0",
		"eslint": "10.5.0",
		"eslint-plugin-jsdoc": "63.0.5",
		"eslint-plugin-jsonc": "3.2.0",
		"eslint-plugin-markdown": "5.1.0",
		"eslint-plugin-n": "18.1.0",
		"eslint-plugin-package-json": "1.5.0",
		"eslint-plugin-perfectionist": "5.9.0",
		"eslint-plugin-regexp": "3.1.0",
		"eslint-plugin-yml": "3.4.0",
		"knip": "6.18.0",
		"lefthook": "2.1.0",
		"markdownlint-cli": "0.49.0",
		"markdownlint-sentences-per-line": "0.1.1",
		"prettier": "3.8.1",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-curly": "0.4.0",
		"prettier-plugin-packagejson": "3.0.0",
		"prettier-plugin-sh": "0.18.0",
		"release-it": "20.2.0",
		"type-fest": "5.7.0",
		"typescript": "5.9.2",
		"typescript-eslint": "8.58.0",
		"vitest": "4.1.0"
	},
	"packageManager": "pnpm@10.34.3",
	"engines": {
		"node": ">=24.0.0"
	}
}
